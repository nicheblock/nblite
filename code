<style>:root { --banner: #01050e; --text: #ffffff; --card-size: 180px; --accent: #5986da; --font-family: 'Press Start 2P', cursive; }
body { font-family: var(--font-family); color: var(--text); margin: 0; background-image: url("https://i.ytimg.com/vi/EMThTRv-dH0/hq720.jpg?sqp=-oaymwEhCK4FEIIDSFryq4qpAxMIARUAAAAAGAElAADIQj0AgKJD&rs=AOn4CLBcwdI76yVgYx931ZPMZSO2do1WhA"); background-color: rgb(10, 10, 10); background-size: cover; background-attachment: fixed; }
.top-bar { background: var(--banner); padding: 10px 30px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.1); min-height: 75px; gap: 20px; }
.fx-shiny { background: linear-gradient(to right, var(--text) 20%, var(--accent) 40%, var(--accent) 60%, var(--text) 80%); background-size: 200% auto; background-clip: text; -webkit-background-clip: text; -webkit-text-fill-color: transparent; animation: shine 3s linear infinite; }
@keyframes shine { to { background-position: 200% center; } }
.fx-animated { animation: float 3s ease-in-out infinite; display: inline-block; }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
.logo-left { order: 1; margin-right: auto; } .logo-right { order: 5; margin-left: auto; }
#grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(var(--card-size), 1fr)); gap: 20px; padding: 30px; }
.game-card { background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); overflow: hidden; aspect-ratio: 1/1.1; display: flex; flex-direction: column; cursor: pointer; transition: 0.3s;}
.card-img { flex-grow: 1; background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; font-weight: 900; color: var(--accent); background-color: rgba(0,0,0,0.3); }
.card-footer { background: rgba(0,0,0,0.7); padding: 12px; font-size: 0.9rem; font-weight: bold; text-align: center; }
</style></head><body>
